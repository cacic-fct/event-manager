{
  "name": "public",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/public/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "baseHref": "/app/",
        "outputPath": "dist/apps/public",
        "browser": "apps/public/src/main.ts",
        "tsConfig": "apps/public/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/public/public"
          },
          "apps/public/src/robots.txt",
          "apps/public/src/.well-known/security.txt"
        ],
        "styles": [
          "apps/public/src/styles.scss"
        ],
        "server": "apps/public/src/main.server.ts",
        "ssr": {
          "entry": "apps/public/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "5kb",
              "maximumError": "10kb"
            }
          ],
          "outputHashing": "all",
          "serviceWorker": "apps/public/ngsw-config.json"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "apps/cacic-eventos/src/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "public:build:production"
        },
        "development": {
          "buildTarget": "public:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false,
        "code-coverage": true
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "public:build",
        "port": 4200,
        "staticFilePath": "dist/apps/public/browser",
        "spa": true
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "apps/public/.storybook",
        "browserTarget": "public:build-storybook",
        "compodoc": true,
        "compodocArgs": [
          "-e",
          "json",
          "-d",
          "apps/public/.storybook/compodoc"
        ],
        "styles": [
          "@fontsource/material-icons-outlined",
          "@fontsource-variable/inter",
          "apps/public/src/styles.scss"
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/public",
        "configDir": "apps/public/.storybook",
        "browserTarget": "public:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c apps/public/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "public:build-storybook",
        "staticFilePath": "dist/storybook/public",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "public:build-storybook:ci"
        }
      }
    }
  }
}
{
  "name": "backend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:e2e", "scope:backend", "type:e2e"],
  "implicitDependencies": [
    "backend"
  ],
  "targets": {
    "e2e": {
      "outputs": [
        "{workspaceRoot}/coverage/{e2eProjectRoot}",
        "{workspaceRoot}/coverage/backend-e2e"
      ],
      "options": {
        "passWithNoTests": true
      }
    },
    "e2e-keycloak": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/backend-e2e"],
      "options": {
        "command": "node tools/run-backend-keycloak-e2e.mjs",
        "forwardAllArgs": true
      }
    }
  }
}

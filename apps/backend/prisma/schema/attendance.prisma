model EventAttendance {
  personId String
  eventId  String

  person People @relation(fields: [personId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])

  category AttendanceCategory @default(UNKNOWN)

  attendedAt DateTime @default(now())

  createdAt       DateTime                 @default(now())
  createdById     String?
  committedById   String?
  createdByMethod AttendanceCreationMethod @default(UNKNOWN)

  collectedLatitude       Float?
  collectedLongitude      Float?
  collectedAccuracyMeters Float?

  @@id([personId, eventId])
  @@index([eventId])
  @@index([personId])
  @@index([committedById])
  @@map("event_attendances")
}

model EventAttendanceCollector {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  personId String
  person   People @relation(fields: [personId], references: [id])

  createdAt   DateTime @default(now())
  createdById String?

  @@id([eventId, personId])
  @@index([personId])
  @@map("event_attendance_collectors")
}

model OfflineEventAttendanceSubmission {
  id String @id @default(uuid(7))

  clientId String

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  personId String?
  person   People? @relation(fields: [personId], references: [id])

  status OfflineEventAttendanceSubmissionStatus @default(PENDING)

  createdByMethod AttendanceCreationMethod
  scannerCode     String?
  manualValue     String?
  collectedAt     DateTime

  authorUserId String?
  authorName   String?
  authorEmail  String?

  submittedById String
  submittedAt   DateTime @default(now())

  stagedReason    String?
  resolutionError String?

  collectedLatitude       Float?
  collectedLongitude      Float?
  collectedAccuracyMeters Float?

  committedAt   DateTime?
  committedById String?

  rejectedAt     DateTime?
  rejectedById   String?
  rejectionReason String?

  @@unique([submittedById, clientId])
  @@index([eventId, status])
  @@index([personId])
  @@index([submittedById])
  @@index([committedById])
  @@index([rejectedById])
  @@map("offline_event_attendance_submissions")
}

enum AttendanceCreationMethod {
  CSV_IMPORT
  MANUAL_INPUT
  SCANNER
  ONLINE_CODE
  UNKNOWN
}

enum AttendanceCategory {
  NON_PAYING
  NON_SUBSCRIBED
  REGULAR
  UNKNOWN
}

enum OfflineEventAttendanceSubmissionStatus {
  PENDING
  COMMITTED
  REJECTED
}

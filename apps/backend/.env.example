
# Database Configuration

# PostgreSQL connection string for Prisma ORM
# Required for all environments
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"


# Cache Configuration

# Redis connection URL
# Used for caching and session management
REDIS_URL="redis://localhost:6379/0"


# Server Configuration

# HTTP server port (defaults to 3000 if not set)
PORT="3000"

# Canonical public origin used in generated calendar URLs
# Avoids trusting client-controlled forwarded headers
PUBLIC_APP_ORIGIN=http://localhost:4200

# Node environment (development/production)
# Affects logging, error handling, and optimization
NODE_ENV="development"


# Keycloak Authentication Configuration

# Keycloak realm base URL
# Format: https://<keycloak-host>/realms/<realm-name>
KEYCLOAK_REALM_URL="https://sso.cacic.dev.br/realms/cacic-sso"

# OAuth 2.0 Client ID
# Must be configured in Keycloak
KEYCLOAK_CLIENT_ID="cacic-event-manager"

# OAuth 2.0 Client Secret
# REQUIRED - Must be set for authentication to work
# Retrieve from Keycloak admin console
KEYCLOAK_CLIENT_SECRET="your-secret-here"

# OAuth callback URL
# Where Keycloak redirects after user login
KEYCLOAK_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Allowed OAuth callback origins (comma-separated)
# Security setting to prevent callback URI injection through query params or forwarded headers
# KEYCLOAK_REDIRECT_URI is included automatically
KEYCLOAK_ALLOWED_CALLBACK_REDIRECT_ORIGINS=""

# Post-login redirect URL for frontend
# Where users are redirected after successful authentication
KEYCLOAK_POST_LOGIN_REDIRECT_URI="http://localhost:4200"

# Post-logout redirect URL
# Where users are redirected after logout
# Optional - if not set, users are redirected to Keycloak logout page
KEYCLOAK_POST_LOGOUT_REDIRECT_URI="http://localhost:4200"

# Allowed post-login redirect origins (comma-separated)
# Security setting to prevent open redirect attacks
# Leave empty to use default behavior
KEYCLOAK_ALLOWED_POST_LOGIN_REDIRECT_ORIGINS=""

# Token introspection cache TTL in milliseconds
# Reduces load on Keycloak by caching token validation
# Recommended: 5000-30000ms
KEYCLOAK_INTROSPECTION_CACHE_TTL_MS="10000"

# Auth session refresh lock TTL in milliseconds
# Prevents concurrent requests from refreshing the same session at the same time
KEYCLOAK_AUTH_REFRESH_LOCK_TTL_MS="5000"

# Maximum time a request waits for another request to refresh the same session
KEYCLOAK_AUTH_REFRESH_LOCK_WAIT_MS="2500"

# Poll interval while waiting for a session refresh lock to clear
KEYCLOAK_AUTH_REFRESH_LOCK_POLL_MS="50"

# Server-side pepper used to hash private calendar feed bearer tokens
CALENDAR_FEED_KEY_PEPPER=replace-with-a-long-random-secret


# Keycloak Machine-to-Machine (M2M) Configuration
#
# One confidential service-account client should identify this backend when it
# calls other backends. Keep target-specific API URLs and audiences separate.
KEYCLOAK_M2M_CLIENT_ID="cacic-event-manager-m2m"
KEYCLOAK_M2M_CLIENT_SECRET="your-event-manager-m2m-secret"

# Require service account tokens for M2M authentication
# Set to "true" to enforce only service account tokens
# Set to "false" to allow any token type (less secure)
KEYCLOAK_M2M_REQUIRE_SERVICE_ACCOUNT="true"

# Required audience claim for M2M tokens
# Production should set this to the Event Manager API audience/resource client ID
KEYCLOAK_M2M_AUDIENCE="cacic-event-manager-audience"

# Allowed M2M client IDs (comma-separated)
# Restricts M2M access to specific clients
# Production should include only known service-account clients
# cacic-voto-m2m needs the voting-integration:read role to list linkable
# events and verify attendance for restricted voting.
KEYCLOAK_M2M_ALLOWED_CLIENTS="cacic-account-manager-m2m,cacic-voto-m2m"

# Account Manager M2M target
ACCOUNT_MANAGER_API_URL="https://account.cacic.dev.br/api"
ACCOUNT_MANAGER_M2M_AUDIENCE="cacic-account-manager-audience"
# Account Manager calls use the backend service-account credentials above.
# Configure the Keycloak audience mapper as a default client scope on KEYCLOAK_M2M_CLIENT_ID.


# Novu Notifications Configuration

# Enables signed Novu browser sessions and server-side notification triggers.
# Production deployments should keep this enabled when NOVU_SECRET_KEY is set.
NOVU_SECURE_MODE_ENABLED="true"

# Server-side Novu secret key used to trigger workflows and sign subscriber sessions.
NOVU_SECRET_KEY="your-novu-secret-key"

# Server-side Novu API URL. Leave empty to use the default Novu cloud API.
NOVU_API_URL="https://api.novu.co"

# Public Novu application identifier used by the browser SDK.
NOVU_APPLICATION_IDENTIFIER="your-novu-application-identifier"

# Optional browser SDK API and socket endpoints for self-hosted Novu deployments.
NOVU_CLIENT_API_URL=""
NOVU_CLIENT_SOCKET_URL=""
NOVU_CLIENT_SOCKET_PATH=""

# Optional browser push configuration.
NOVU_PUSH_INTEGRATION_IDENTIFIER=""
NOVU_VAPID_PUBLIC_KEY=""

# Optional override for the major-event subscription status workflow.
NOVU_MAJOR_EVENT_SUBSCRIPTION_WORKFLOW_IDENTIFIER="major-event-subscription-status-changed"


# Search Configuration (Typesense)

# Enable/disable full-text search indexing.
# Keep enabled in development when using docker/docker-compose.dev.yml.
TYPESENSE_ENABLED="true"

# Development uses the docker-compose service exposed on localhost
# Production uses https://typesense.cacic.dev.br.
TYPESENSE_URL="http://localhost:8108"

# Development key standardized by docker/docker-compose.dev.yml.
# Production must set the real API key in the deployment environment.
TYPESENSE_API_KEY="xyz"


# Cloudflare Turnstile

# Server-side secret key used to validate Turnstile tokens.
# Development defaults to Cloudflare's always-pass test secret when validation is explicitly enabled.
# Production must set a real secret key from the Cloudflare dashboard.
TURNSTILE_SECRET_KEY=""

# Optional comma-separated hostname allowlist checked against Cloudflare's response.
TURNSTILE_EXPECTED_HOSTNAMES=""

# Optional validation timeout in milliseconds. Defaults to 3000 and is capped at 10000.
TURNSTILE_SITEVERIFY_TIMEOUT_MS="3000"

# Development-only switch. Keep false locally; Angular still renders Cloudflare's visible test widget for UI checks.
# Set true only when testing server-side validation with Cloudflare's dummy keys. Ignored in production.
TURNSTILE_ENABLED="false"

# Database and cache

# REQUIRED. PostgreSQL connection string for Prisma ORM.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"

# Optional. Redis URL for queues, weather jobs, OAuth state, and sessions.
# Defaults to redis://localhost:6379 when omitted.
REDIS_URL="redis://localhost:6379/0"


# Server

# Optional. HTTP server port. Defaults to 3000.
PORT="3000"

# Optional. Use "production" only for production runtime behavior.
NODE_ENV="development"

# REQUIRED IN PRODUCTION. Canonical public app origin used in generated links,
# especially calendar feeds. Local default is http://localhost:4200.
PUBLIC_APP_ORIGIN="http://localhost:4200"

# Optional. Public backend URL used to derive shared CACiC cookie domain when
# CACIC_SHARED_COOKIE_DOMAIN is not set.
BACKEND_URL="http://localhost:3000/api"

# Optional. Overrides shared tracking cookie domain.
# Production usually uses ".cacic.dev.br".
CACIC_SHARED_COOKIE_DOMAIN=""


# Human Keycloak authentication

# REQUIRED IN PRODUCTION. Defaults to https://sso.cacic.dev.br/realms/cacic-sso in development.
KEYCLOAK_REALM_URL="https://sso.cacic.dev.br/realms/cacic-sso"

# REQUIRED IN PRODUCTION. Must match the confidential client that owns KEYCLOAK_CLIENT_SECRET.
KEYCLOAK_CLIENT_ID="cacic-event-manager"

# REQUIRED IN PRODUCTION. Confidential OAuth client secret.
KEYCLOAK_CLIENT_SECRET="your-human-auth-client-secret"

# Optional. Must match the client's Token Endpoint Auth Method in Keycloak.
# Supported values: client_secret_basic, client_secret_post. Defaults to client_secret_basic.
KEYCLOAK_TOKEN_ENDPOINT_AUTH_METHOD="client_secret_basic"

# REQUIRED IN PRODUCTION. Must be the exact backend callback route registered in Keycloak,
# without query params or hash. Login normally derives this from forwarded headers, but this
# remains the fallback and is included in the callback-origin allowlist.
KEYCLOAK_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Optional. Extra allowed callback origins, comma-separated.
KEYCLOAK_ALLOWED_CALLBACK_REDIRECT_ORIGINS=""

# REQUIRED IN PRODUCTION. Default browser destination after login when no
# returnTo is stored in OAuth state.
KEYCLOAK_POST_LOGIN_REDIRECT_URI="http://localhost:4200"

# REQUIRED IN PRODUCTION. Default browser destination after logout.
KEYCLOAK_POST_LOGOUT_REDIRECT_URI="http://localhost:4200"

# Optional. Extra allowed post-login redirect origins, comma-separated.
KEYCLOAK_ALLOWED_POST_LOGIN_REDIRECT_ORIGINS=""

# Optional. Extra allowed post-logout redirect origins, comma-separated.
KEYCLOAK_ALLOWED_POST_LOGOUT_REDIRECT_ORIGINS=""

# Optional. Extra clients whose human access tokens are accepted.
KEYCLOAK_ALLOWED_ACCESS_TOKEN_CLIENTS=""

# Optional. Token introspection cache TTL in milliseconds. Defaults to 10000.
KEYCLOAK_INTROSPECTION_CACHE_TTL_MS="10000"

# Optional. Redis key prefix for server-side auth sessions.
KEYCLOAK_AUTH_SESSION_REDIS_PREFIX="auth:session:"

# Optional. Redis key prefix for OAuth state.
KEYCLOAK_AUTH_STATE_REDIS_PREFIX="auth:oauth-state:"

# Optional. OAuth state TTL in seconds. Defaults to 600.
KEYCLOAK_AUTH_STATE_TTL_SECONDS="600"

# Optional. Auth session refresh lock TTL in milliseconds. Defaults to 5000.
KEYCLOAK_AUTH_REFRESH_LOCK_TTL_MS="5000"

# Optional. Maximum time a request waits for another refresh lock in
# milliseconds. Defaults to 2500.
KEYCLOAK_AUTH_REFRESH_LOCK_WAIT_MS="2500"

# Optional. Poll interval while waiting for a refresh lock in milliseconds.
# Defaults to 50.
KEYCLOAK_AUTH_REFRESH_LOCK_POLL_MS="50"


# Machine-to-machine authentication

# REQUIRED IN PRODUCTION. Used when calling Account Manager or other M2M backends.
KEYCLOAK_M2M_CLIENT_ID="cacic-event-manager-m2m"

# REQUIRED IN PRODUCTION. Used when calling Account Manager or other M2M backends.
KEYCLOAK_M2M_CLIENT_SECRET="your-event-manager-m2m-secret"

# Optional. Defaults to true. Keep true in production.
KEYCLOAK_M2M_REQUIRE_SERVICE_ACCOUNT="true"

# REQUIRED IN PRODUCTION. Event Manager API audience/resource
# client id expected in service-account tokens.
KEYCLOAK_M2M_AUDIENCE="cacic-event-manager-audience"

# REQUIRED IN PRODUCTION. Comma-separated client id allowlist for M2M callers.
KEYCLOAK_M2M_ALLOWED_CLIENTS="cacic-account-manager-m2m,cacic-voto-m2m"


# Account Manager integration

# Optional. Defaults to https://account.cacic.dev.br/api.
ACCOUNT_MANAGER_API_URL="https://account.cacic.dev.br/api"

# REQUIRED IN PRODUCTION. Target audience for Account Manager M2M calls.
ACCOUNT_MANAGER_M2M_AUDIENCE="cacic-account-manager-audience"


# Calendar feeds

# REQUIRED IN PRODUCTION when private calendar feeds are used. Server-side
# pepper used to hash private calendar feed bearer tokens.
CALENDAR_FEED_KEY_PEPPER="replace-with-a-long-random-secret"


# S3-compatible object storage

# REQUIRED WHEN LGPD exports, receipt uploads, or other file storage features
# are used.
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET_NAME=""

# Optional. Defaults to us-east-1.
S3_REGION="us-east-1"


# Novu notifications

# Optional. Set true to enable signed Novu browser sessions and server-side
# notification triggers.
NOVU_SECURE_MODE_ENABLED="false"

# REQUIRED WHEN NOVU_SECURE_MODE_ENABLED=true.
NOVU_SECRET_KEY=""

# Optional. Defaults to https://api.novu.co.
NOVU_API_URL="https://api.novu.co"

# REQUIRED WHEN NOVU_SECURE_MODE_ENABLED=true and browser inbox sessions are used.
NOVU_APPLICATION_IDENTIFIER=""

# Optional browser SDK endpoints for self-hosted Novu deployments.
NOVU_CLIENT_API_URL=""
NOVU_CLIENT_SOCKET_URL=""
NOVU_CLIENT_SOCKET_PATH=""

# Optional browser push configuration.
NOVU_PUSH_INTEGRATION_IDENTIFIER=""
NOVU_VAPID_PUBLIC_KEY=""

# Optional. Defaults to major-event-subscription-status-changed.
NOVU_MAJOR_EVENT_SUBSCRIPTION_WORKFLOW_IDENTIFIER="major-event-subscription-status-changed"


# Typesense search

# Optional. Set true to enable full-text search indexing.
TYPESENSE_ENABLED="false"

# REQUIRED WHEN TYPESENSE_ENABLED=true.
TYPESENSE_URL="http://localhost:8108"

# REQUIRED WHEN TYPESENSE_ENABLED=true.
TYPESENSE_API_KEY=""


# Cloudflare Turnstile

# Optional. Set true to enforce server-side Turnstile validation.
TURNSTILE_ENABLED="false"

# REQUIRED IN PRODUCTION, and whenever TURNSTILE_ENABLED=true.
TURNSTILE_SECRET_KEY=""

# Optional. Override Cloudflare siteverify endpoint.
TURNSTILE_SITEVERIFY_URL="https://challenges.cloudflare.com/turnstile/v0/siteverify"

# Optional. Comma-separated hostname allowlist checked against Cloudflare.
TURNSTILE_EXPECTED_HOSTNAMES=""

# Optional. Validation timeout in milliseconds. Defaults to 3000 and is capped.
TURNSTILE_SITEVERIFY_TIMEOUT_MS="3000"


# Public app SSR

# REQUIRED IN PRODUCTION. Public Cloudflare Turnstile site key injected into the
# rendered public app.
TURNSTILE_SITE_KEY=""

{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@cacic-fct/shared-data-types": ["./libs/shared-data-types/src/index.ts"],
      "@cacic-fct/shared-utils": ["./libs/shared-utils/src/index.ts"],
      "@cacic-fct/shared-permissions": ["./libs/shared-permissions/src/index.ts"],
      "@cacic-fct/shared-frontend-types": ["./libs/shared-data-types/src/lib/frontend-types.ts"],
      "@cacic-fct/shared-angular": ["./libs/shared-angular/src/index.ts"],
      "@cacic-fct/shared-environment": ["./libs/shared-environment/src/index.ts"],
      "@cacic-fct/shared-notifications-angular": ["./libs/shared-notifications-angular/src/index.ts"],
      "@cacic-fct/offline-public-data-access": ["./libs/offline-public-data-access/src/index.ts"],
      "@cacic-fct/event-manager-public-contracts": ["./libs/event-manager-public-contracts/src/index.ts"],
      "@cacic-fct/event-manager-public-contracts/types": [
        "./libs/event-manager-public-contracts/src/lib/types/index.ts"
      ],
      "@cacic-fct/event-manager-public-contracts/types/events": [
        "./libs/event-manager-public-contracts/src/lib/types/events.ts"
      ],
      "@cacic-fct/event-manager-public-contracts/types/certificates": [
        "./libs/event-manager-public-contracts/src/lib/types/certificates.ts"
      ],
      "@cacic-fct/event-manager-public-contracts/graphql": [
        "./libs/event-manager-public-contracts/src/lib/graphql/index.ts"
      ],
      "@cacic-fct/event-manager-public-contracts/graphql/fragments": [
        "./libs/event-manager-public-contracts/src/lib/graphql/fragments.ts"
      ],
      "@cacic-fct/event-manager-public-contracts/graphql/queries": [
        "./libs/event-manager-public-contracts/src/lib/graphql/queries.ts"
      ],
      "@cacic-fct/event-manager-m2m-contracts": ["./libs/event-manager-m2m-contracts/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

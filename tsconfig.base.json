{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cacic-fct/shared-data-types": ["libs/shared-data-types/src/index.ts"],
      "@cacic-fct/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@cacic-fct/shared-frontend-types": ["libs/shared-data-types/src/lib/frontend-types.ts"],
      "@cacic-fct/shared-angular": ["libs/shared-angular/src/index.ts"],
      "@cacic-fct/cookie-banner/angular": ["libs/shared-angular/src/lib/cookie-banner/index.ts"],
      "@cacic-fct/shared-environment": ["libs/shared-environment/src/index.ts"],
      "@cacic-fct/shared-notifications-angular": ["libs/shared-notifications-angular/src/index.ts"],
      "@cacic-fct/offline-public-data-access": ["libs/offline-public-data-access/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

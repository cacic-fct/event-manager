{
  "realm": "cacic-sso",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "requiredCredentials": ["password"],
  "roles": {
    "realm": [
      {
        "name": "default-roles-cacic-sso",
        "description": "Default realm roles for development users",
        "composite": true,
        "clientRole": false,
        "composites": {
          "realm": ["offline_access", "uma_authorization"],
          "client": {
            "account": ["manage-account", "view-profile"]
          }
        }
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "clientRole": false
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "clientRole": false
      }
    ],
    "client": {
      "cacic-account-manager": [
        {
          "name": "access",
          "description": "Can access CACiC Account Manager admin-aware surfaces",
          "clientRole": true
        },
        {
          "name": "super-admin",
          "description": "Full CACiC Account Manager administration",
          "clientRole": true
        }
      ],
      "cacic-event-manager": [
        {
          "name": "access",
          "description": "Can access CACiC Event Manager admin app",
          "clientRole": true
        },
        {
          "name": "super-admin",
          "description": "Full CACiC Event Manager administration",
          "clientRole": true
        }
      ],
      "cacic-account-manager-audience": [
        {
          "name": "privacy:read",
          "description": "Read account privacy data over M2M",
          "clientRole": true
        },
        {
          "name": "privacy:write",
          "description": "Write account privacy data over M2M",
          "clientRole": true
        }
      ],
      "cacic-event-manager-audience": [
        {
          "name": "account-profile:write",
          "description": "Write profile updates received from Account Manager",
          "clientRole": true
        },
        {
          "name": "account-merge:score",
          "description": "Score possible account merges",
          "clientRole": true
        },
        {
          "name": "account-merge:write",
          "description": "Apply account merge decisions",
          "clientRole": true
        },
        {
          "name": "lgpd:read",
          "description": "Read LGPD data over M2M",
          "clientRole": true
        },
        {
          "name": "lgpd:delete",
          "description": "Delete LGPD data over M2M",
          "clientRole": true
        },
        {
          "name": "voting-integration:read",
          "description": "Read voting integration data over M2M",
          "clientRole": true
        }
      ]
    }
  },
  "groups": [
    {
      "name": "Super Admins",
      "clientRoles": {
        "cacic-account-manager": ["access", "super-admin"],
        "cacic-event-manager": ["access", "super-admin"]
      },
      "subGroups": [
        {
          "name": "Discord Admin"
        }
      ]
    },
    {
      "name": "Unesp"
    },
    {
      "name": "student-entities",
      "subGroups": [
        {
          "name": "cacic",
          "clientRoles": {
            "cacic-account-manager": ["access"]
          }
        },
        {
          "name": "ejcomp",
          "clientRoles": {
            "cacic-account-manager": ["access"]
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${profileScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "preferred username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "set_fullname",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "fullName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "set_fullname",
            "jsonType.label": "String"
          }
        },
        {
          "name": "is_onboarded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "isOnboarded",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "is_onboarded",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${emailScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "emailVerified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${rolesScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },

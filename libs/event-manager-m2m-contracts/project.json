{
  "name": "event-manager-m2m-contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/event-manager-m2m-contracts/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/event-manager-m2m-contracts"],
      "options": {
        "cwd": "libs/event-manager-m2m-contracts",
        "command": "bun run tsc -p tsconfig.lib.json && cp package.json README.md ../../dist/libs/event-manager-m2m-contracts/"
      }
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "dist/libs/event-manager-m2m-contracts",
        "command": "bun publish --access public"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/event-manager-m2m-contracts"],
      "options": {
        "command": "bunx vitest run --coverage --config libs/event-manager-m2m-contracts/vitest.config.ts"
      }
    }
  }
}

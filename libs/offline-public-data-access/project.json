{
  "name": "offline-public-data-access",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/offline-public-data-access",
  "sourceRoot": "libs/offline-public-data-access/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        {
          "externalDependencies": [
            "eslint"
          ]
        }
      ],
      "options": {
        "args": [
          "**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/offline-public-data-access"],
      "options": {
        "command": "bunx vitest run --coverage --config libs/offline-public-data-access/vitest.config.ts"
      }
    }
  }
}
